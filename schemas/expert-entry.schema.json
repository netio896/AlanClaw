{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://alanclaw.dev/schemas/expert-entry.schema.json",
  "title": "AlanClaw Expert Entry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "slug",
    "title",
    "category",
    "card_summary",
    "about_text",
    "system_prompt",
    "tags",
    "languages_supported",
    "channels_supported",
    "featured",
    "sort_order"
  ],
  "properties": {
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "category": {
      "type": "string",
      "minLength": 1
    },
    "card_summary": {
      "type": "string",
      "minLength": 1
    },
    "about_text": {
      "type": "string",
      "minLength": 1
    },
    "system_prompt": {
      "type": "string",
      "minLength": 1
    },
    "tags": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "languages_supported": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "channels_supported": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "featured": {
      "type": "boolean"
    },
    "sort_order": {
      "type": "integer",
      "minimum": 1
    }
  }
}
