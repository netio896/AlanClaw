{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://alanclaw.local/schemas/team-template.schema.json",
  "title": "AlanClaw Team Template",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "slug",
    "title",
    "industry",
    "card_summary",
    "use_cases",
    "recommended_experts",
    "languages_supported",
    "channels_supported",
    "featured",
    "sort_order"
  ],
  "properties": {
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "industry": {
      "type": "string",
      "minLength": 1
    },
    "card_summary": {
      "type": "string",
      "minLength": 1
    },
    "use_cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "recommended_experts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["slug", "role", "reason"],
        "properties": {
          "slug": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "role": {
            "type": "string",
            "minLength": 1
          },
          "reason": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "languages_supported": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "channels_supported": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "featured": {
      "type": "boolean"
    },
    "sort_order": {
      "type": "integer",
      "minimum": 1
    }
  }
}
